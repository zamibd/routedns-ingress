/var/log/haproxy.log {
    daily
    rotate 14
    missingok
    notifempty
    compress
    delaycompress
    sharedscripts
    postrotate
        /usr/local/lib/routedns-ingress/logrotate-postrotate.sh
    endscript
}

/var/log/keepalived.log {
    weekly
    rotate 8
    missingok
    notifempty
    compress
    delaycompress
    sharedscripts
    postrotate
        /usr/local/lib/routedns-ingress/logrotate-postrotate.sh
    endscript
}
