# routedns-ingress — production setup
# 1. Copy:  cp .env.example .env
# 2. Edit:  set backend IPs + VIP + ROLE
# 3. Run:   sudo make setup

# ---------------------------------------------------------------------------
# Backend HAProxy servers (at least one required)
#
# Option A — numbered (any count, no gaps): BACKEND_1, BACKEND_2, BACKEND_3, ...
# Option B — comma-separated list (overrides BACKEND_N when set):
#   BACKENDS=10.0.1.10,10.0.1.11,10.0.1.12
# ---------------------------------------------------------------------------
BACKEND_1=10.0.1.10
BACKEND_2=10.0.1.11
BACKEND_3=10.0.1.12
# BACKEND_4=10.0.1.13
# BACKENDS=10.0.1.10,10.0.1.11,10.0.1.12,10.0.1.13,10.0.1.14

# ---------------------------------------------------------------------------
# Virtual IP — clients connect here for DNS-over-TLS (required)
# ---------------------------------------------------------------------------
VIP=10.0.0.100
# Use /32 for cloud floating/reserved IPs (Vultr, GCP); /24 for on-prem L2
VIP_PREFIX=24

# ---------------------------------------------------------------------------
# Node role: master (primary) or backup (secondary)
# ---------------------------------------------------------------------------
ROLE=master

# ---------------------------------------------------------------------------
# Optional — leave empty for auto-detect / auto-generate
# ---------------------------------------------------------------------------
# Network interface (auto-detected from default route if empty)
# INTERFACE=eth0

# VRRP shared secret, max 8 chars (auto-generated on first setup if empty)
# VRRP_SECRET=

# This host's primary IPv4 on INTERFACE (auto-detected if empty)
# NODE_IP=

# Peer node's primary IPv4 for VRRP unicast (required when multicast is blocked — most clouds)
# Master: set to backup's primary IP. Backup: set to master's primary IP.
# VRRP_PEER=10.0.0.11

# Backend port (default 853)
BACKEND_PORT=853

# Send PROXY Protocol v2 to backends (yes/no)
USE_PROXY_PROTOCOL=yes

# Configure firewall: ssh + DoT only (yes/no)
CONFIGURE_FIREWALL=yes

# Install latest upstream packages (yes/no)
# When yes: HAProxy 3.4.1 + Keepalived 2.4.1 (repo or source build per OS)
INSTALL_LATEST_PACKAGES=no

# Target versions when INSTALL_LATEST_PACKAGES=yes
HAPROXY_VERSION=3.4.1
KEEPALIVED_VERSION=2.4.1
